# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_GUILD_ID=your_guild_id_here

# Discord OAuth2 Configuration (for web authentication)
DISCORD_CLIENT_ID=your_discord_app_client_id_here
DISCORD_CLIENT_SECRET=your_discord_app_client_secret_here
DISCORD_REDIRECT_URI=http://localhost:3001/auth/callback

# JWT Configuration
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# REQUIRED: must be at least 32 characters; the default above will cause startup to fail.
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET_MIN_32_CHARS
JWT_EXPIRATION_HOURS=8

# Access Control
# Comma-separated Discord Role IDs that are allowed to access the web interface.
# Users without any of these roles will be redirected to the "Unauthorized" page after login.
# Admins (ADMIN_ROLE_IDS / ADMIN_USER_IDS) and guests (GUEST_USER_IDS) always bypass this check.
# If left empty, any user who is a member of the server will be granted access.
ALLOWED_ROLE_IDS=123456789012345678,987654321098765432

# Admin Configuration
ADMIN_ROLE_IDS=123456789012345678,987654321098765432
ADMIN_USER_IDS=your_admin_user_id_here

# Moderator Configuration
# Comma-separated list of Discord Role IDs that have moderator permissions
# These roles can use certain commands like /analyze_activity
MOD_ROLE_IDS=123456789012345678,987654321098765432

# Guest User IDs
# Comma-separated list of Discord User IDs that can access the website without being on the server
# These users bypass both server membership and role requirements
GUEST_USER_IDS=

# User Filter Roles
# Comma-separated list of Discord Role IDs that will be shown as filter options on the Users page
# Role names and colors will be automatically fetched from the database
FILTER_ROLES=123456789012345678,987654321098765432

# Default Filter Role
# The role ID that should be selected by default when the Users page loads
# Use "all" for all users, or a specific role ID from FILTER_ROLES
# Leave empty to show no users by default (user must select a filter)
DEFAULT_FILTER_ROLE=123456789012345678

# API Configuration
# Set ENVIRONMENT=production to disable Swagger UI and enable HSTS
ENVIRONMENT=development
API_HOST=127.0.0.1
API_PORT=8000

# CORS — comma-separated list of allowed frontend origins
# Add your production domain here, e.g. https://community.example.com
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Database Configuration 
DATABASE_PATH=./data/tracking.db

# Frontend Configuration
REACT_APP_API_URL=http://localhost:8000

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Raid-Helper Configuration
RAIDHELPER_API_KEY=your_raidhelper_api_key_here

# News Channel
# Discord Channel ID whose messages are automatically saved as news posts
NEWS_CHANNEL_ID=your_announcement_channel_id_here

# Jungle Sound Bot Configuration
# Voice channel IDs for the /js command
JUNGLE_CHANNEL_1_ID=your_voice_channel_1_id_here
JUNGLE_CHANNEL_2_ID=your_voice_channel_2_id_here
# Paths to audio files (relative to the project root / container /app directory)
SOUNDBOT_INTRO_FILE=sounds/jungle_intro.mp3
SOUNDBOT_LOOP_FILE=sounds/jungle.mp3
# Interval between full rotations in seconds (default: 300 = 5 minutes)
JUNGLE_INTERVAL_SECONDS=300